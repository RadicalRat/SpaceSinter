<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Suntracking_Test">
  <!--//////////-->
  <BehaviorTree
    ID="Suntracking_Test"
    _description="Objective to test Suntracking Behavior"
    _favorite="false"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action ID="EstimateSunPose" cameraOrientation="{orientation}" />
      <Action
        ID="CreateStampedPose"
        orientation_xyzw="{orientation}"
        position_xyz="0;0;0"
        reference_frame="camera"
      />
      <Action ID="TransformPoseFrame" input_pose="{stamped_pose}" />
      <SubTree
        ID="Move to Pose"
        _collapsed="true"
        target_pose="{output_pose}"
        controller_names="joint_trajectory_controller;robotiq_gripper_controller"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Suntracking_Test">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Sinter" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
