# Kinova Gen2 robot arm — USB device permissions
#
# Without this rule the device is root-only.  Non-root processes and Docker
# containers with /dev:/dev cannot read from the arm, causing all joint state
# values to be reported as zero.
#
# Install on the HOST machine (run once, then replug USB cable):
#   sudo cp 10-kinova-arm.rules /etc/udev/rules.d/
#   sudo udevadm control --reload-rules && sudo udevadm trigger

SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="22cd", ATTR{manufacturer}=="Kinova inc.", MODE:="666"

# Broader fallback (matches all Kinova USB devices regardless of manufacturer string):
SUBSYSTEM=="usb", ENV{DEVTYPE}=="usb_device", ATTR{idVendor}=="22cd", MODE:="666"
