<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="TrackBlob">
  <BehaviorTree
    ID="TrackBlob"
    _description="Track the blob given by the find_sun_pose behvaior"
    _favorite="false"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action ID="GetImage" topic_name="/camera/image_raw" />
      <Action ID="GetCameraInfo" topic_name="/camera/camera_info" />
      <Action
        ID="SaveImageToFile"
        image="{image}"
        file_prefix="image_before"
        file_path="/tmp/trackblob"
      />
      <Action
        ID="SunPoseFinder"
        image="{image}"
        camera_info="{camera_info}"
        cameraOrientation="{est}"
        output_image="{out_image}"
      />
      <Action
        ID="SaveImageToFile"
        image="{out_image}"
        file_path="/tmp/trackblob"
        file_prefix="image_after"
      />
      <Action
        ID="CreateStampedPose"
        stamped_pose="{pose_stamped_1}"
        reference_frame="j2n6s300_suncam_optical"
      />
      <Action ID="VisualizePose" pose="{pose_stamped_1}" marker_name="before" />
      <Control ID="Sequence" name="Create Quaternion Vector">
        <Action ID="UnpackQuaternionMessage" quaternion="{est}" />
        <SubTree
          ID="CreateVector"
          _collapsed="true"
          vector="{quaternion_adjust}"
        />
        <SubTree
          ID="AddToVector"
          _collapsed="true"
          element="{x}"
          input_vector="{quaternion_adjust}"
          output_vector="{quaternion_adjust}"
        />
        <SubTree
          ID="AddToVector"
          element="{y}"
          input_vector="{quaternion_adjust}"
          output_vector="{quaternion_adjust}"
        />
        <SubTree
          ID="AddToVector"
          element="{z}"
          input_vector="{quaternion_adjust}"
          output_vector="{quaternion_adjust}"
        />
        <SubTree
          ID="AddToVector"
          element="{w}"
          input_vector="{quaternion_adjust}"
          output_vector="{quaternion_adjust}"
        />
      </Control>
      <Action
        ID="TransformPose"
        quaternion_xyzw="{quaternion_adjust}"
        input_pose="{pose_stamped_1}"
        output_pose="{camera_pose}"
      />
      <Action ID="VisualizePose" marker_name="end" pose="{camera_pose}" />
      <Control
        ID="Sequence"
        name="Convert focal point to orientation of camera pose"
      >
        <Action
          ID="CreateStampedPose"
          reference_frame="j2n6s300_focal_point"
          stamped_pose="{focal_pose}"
        />
        <Control ID="Sequence" name="unpack focal">
          <Action
            ID="UnpackPoseStampedMessage"
            header="{focal_header}"
            pose="{focal_unpacked}"
            pose_stamped="{focal_pose}"
          />
          <Action
            ID="UnpackPoseMessage"
            position="{focal_position}"
            orientation="{orientation}"
            pose="{focal_unpacked}"
          />
        </Control>
        <Control ID="Sequence" name="Unpack Camera">
          <Action
            ID="UnpackPoseStampedMessage"
            pose="{camera_pose_unpacked}"
            pose_stamped="{camera_pose}"
          />
          <Action
            ID="UnpackPoseMessage"
            pose="{camera_pose_unpacked}"
            orientation="{cam_orientation}"
          />
        </Control>
        <Control ID="Sequence" name="repackfocal">
          <Action
            ID="CreatePoseMessage"
            orientation="{cam_orientation}"
            position="{focal_position}"
            pose="{target_pose_unpacked}"
          />
          <Action
            ID="CreatePoseStampedMessage"
            pose="{target_pose_unpacked}"
            header="{focal_header}"
            pose_stamped="{target_pose}"
          />
          <Action
            ID="TransformPose"
            input_pose="{target_pose}"
            output_pose="{target_pose}"
          />
        </Control>
      </Control>
      <Action ID="VisualizePose" marker_name="target" pose="{target_pose}" />
      <SubTree
        ID="Visualize TF"
        _collapsed="true"
        tf_frame_name="j2n6s300_focal_point"
        marker_name="focal_point"
      />
      <SubTree
        ID="Move to Pose"
        _collapsed="true"
        target_pose="{target_pose}"
        ik_frame="j2n6s300_focal_point"
        require_user_approval="false"
        velocity_scale_factor="1"
        _skipIf="true"
        controller_names="joint_trajectory_admittance_controller"
      />
      <Control ID="Sequence">
        <Action
          ID="InitializeMTCTask"
          controller_names="joint_trajectory_admittance_controller"
          task_id="trackspot"
        />
        <Action ID="SetupMTCCurrentState" />
        <Action
          ID="SetupMTCConnectWithProRRT"
          acceleration_scale_factor="1.000000"
          keep_orientation_link_names="j2n6s300_focal_point"
          link_padding="0.01"
          max_iterations="10000"
          _skipIf="true"
        />
        <Action
          ID="SetupMTCPlanToPose"
          ik_frame="j2n6s300_focal_point"
          keep_orientation="false"
          keep_orientation_link_names="j2n6s300_focal_point"
          link_padding="0.001"
          max_iterations="10000"
        />
        <Action ID="PlanMTCTask" />
        <Action ID="ExecuteMTCSolution" goal_position_tolerance="0.005" />
      </Control>
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="TrackBlob" />
  </TreeNodesModel>
</root>
