<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="Visualize Point Cloud">
  <BehaviorTree ID="Visualize Point Cloud" _description="" _favorite="false">
    <Control ID="Sequence" name="TopLevelSequence">
      <SubTree
        ID="Move to Waypoint"
        _collapsed="true"
        waypoint_name="Scan_Initial"
        _skipIf="true"
      />
      <SubTree ID="Clear Snapshot" _collapsed="true" />
      <Action ID="WaitForDuration" delay_duration="2.000" />
      <Action
        ID="GetPointCloud"
        topic_name="/camera/camera/depth/color/points"
        message_timeout_sec="5.000000"
        message_out="{input_cloud}"
      />
      <Action ID="TransformPointCloudFrame" target_frame="world" />
      <Action
        ID="CreateStampedPose"
        stamped_pose="{roi_frame}"
        orientation_xyzw="0.000; 0.000; 0.000; 1.000"
        reference_frame="realsense_depth_optical_frame"
        position_xyz="0;0;0.5;"
      />
      <Action ID="VisualizePose" pose="{roi_frame}" />
      <Action
        ID="CropPointsInBox"
        crop_box_centroid_pose="{roi_frame}"
        crop_box_size="0.25;0.25;1"
        point_cloud="{output_cloud}"
      />
      <Action
        ID="SendPointCloudToUI"
        pcd_topic="/pcd_pointcloud_captures"
        point_cloud="{point_cloud_cropped}"
      />
      <SubTree
        ID="Visualize TF"
        _collapsed="true"
        marker_name="focal"
        tf_frame_name="j2n6s300_focal_point"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="Visualize Point Cloud">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Sinter" />
      </MetadataFields>
    </SubTree>
  </TreeNodesModel>
</root>
