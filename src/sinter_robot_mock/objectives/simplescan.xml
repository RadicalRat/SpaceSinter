<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="SimpleScan">
  <BehaviorTree
    ID="SimpleScan"
    _description="A simple scanning objective to demonstrate scanning capabilities"
    _favorite="false"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <SubTree
        ID="Visualize TF"
        _collapsed="true"
        tf_frame_name="j2n6s300_focal_point"
        marker_name="focal"
      />
      <Action
        ID="CreateStampedPose"
        position_xyz="-0.05;-1.1;0;"
        stamped_pose="{output_pose}"
        orientation_xyzw="1.000; 0.000; 0.000; 0.000"
      />
      <Action ID="VisualizePose" pose="{output_pose}" marker_name="grid" />
      <Action
        ID="CreateStampedPose"
        position_xyz="-0.995;-0.05;0.005;"
        stamped_pose="{close_pose}"
        orientation_xyzw="-0.685; 0.685; 0.175; -0.175"
      />
      <Action
        ID="GenerateCoveragePath"
        vector_of_poses="{pose_stamped_vector}"
        bottom_right_corner="{output_pose}"
        height="0.01"
        stride_distance="0.005"
        width="0.1"
      />
      <Action ID="VisualizePose" pose="{close_pose}" />
      <SubTree
        ID="Move to Pose"
        _collapsed="true"
        target_pose="{close_pose}"
        ik_frame="j2n6s300_focal_point"
        link_padding="0.01"
        require_user_approval="false"
        _skipIf="true"
      />
      <Action
        ID="VisualizePath"
        marker_lifetime="0.000000"
        marker_name="path"
        path="{pose_stamped_vector}"
        pose_marker_size="0.100000"
        show_poses="1"
      />
      <Action
        ID="PlanCartesianPath"
        acceleration_scale_factor="1.000000"
        blending_radius="0.0002"
        ik_joint_space_density="0.005"
        joint_trajectory_msg="{joint_trajectory_msg}"
        path="{pose_stamped_vector}"
        planning_group_name="manipulator"
        velocity_scale_factor="0.07"
        tip_links="j2n6s300_focal_point"
        position_only="0"
        max_optimizer_iterations="1"
        trajectory_sampling_rate="200"
        ik_cartesian_space_density="0.005"
        tip_offset="0;0;0;0.9;0;0;"
      />
      <Action
        ID="ExecuteTrajectory"
        execution_pipeline="jtac"
        controller_action_name="/joint_trajectory_admittance_controller/follow_joint_trajectory"
        joint_trajectory_msg="{joint_trajectory_msg}"
        absolute_force_torque_threshold="2;2;2;"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="SimpleScan" />
  </TreeNodesModel>
</root>
