<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="MovetoGridPose">
  <!--//////////-->
  <BehaviorTree
    ID="MovetoGridPose"
    _description="Test Objective to create a pose start at same orientation as the current focus point frame. Moves to the new pose"
    _favorite="false"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="CreateStampedPose"
        reference_frame="j2n6s300_focal_point"
        stamped_pose="{tip_pose}"
      />
      <Action
        ID="TransformPoseFrame"
        input_pose="{tip_pose}"
        output_pose="{tip_world_pose}"
      />
      <Action ID="VisualizePose" pose="{tip_world_pose}" marker_name="tip" />
      <Action
        ID="CreateStampedPose"
        reference_frame="world"
        stamped_pose="{grid_pose}"
        position_xyz="-1;0.2;0.2;"
      />
      <Action
        ID="VisualizePose"
        pose="{grid_pose}"
        marker_name="grid"
        _skipIf="true"
      />
      <Action
        ID="UnpackPoseStampedMessage"
        header="{header}"
        pose="{tip_pose_unpacked}"
        pose_stamped="{tip_world_pose}"
      />
      <Action
        ID="UnpackPoseMessage"
        pose="{tip_pose_unpacked}"
        orientation="{tip_orientation}"
        position="{tip_position}"
      />
      <Action
        ID="UnpackQuaternionMessage"
        w="{w}"
        x="{x}"
        quaternion="{tip_orientation}"
      />
      <SubTree
        ID="CreateVector"
        _collapsed="true"
        vector="{orientation_vector}"
      />
      <SubTree
        ID="AddToVector"
        _collapsed="true"
        input_vector="{orientation_vector}"
        element="{x}"
        output_vector="{orientation_vector}"
      />
      <SubTree
        ID="AddToVector"
        _collapsed="true"
        input_vector="{orientation_vector}"
        element="{y}"
        output_vector="{orientation_vector}"
      />
      <SubTree
        ID="AddToVector"
        _collapsed="true"
        input_vector="{orientation_vector}"
        element="{z}"
        output_vector="{orientation_vector}"
      />
      <SubTree
        ID="AddToVector"
        _collapsed="true"
        input_vector="{orientation_vector}"
        element="{w}"
        output_vector="{orientation_vector}"
      />
      <Action
        ID="TransformPose"
        input_pose="{grid_pose}"
        output_pose="{final_pose}"
        quaternion_xyzw="{orientation_vector}"
      />
      <Action
        ID="TransformPoseFrame"
        input_pose="{final_pose}"
        output_pose="{output_pose}"
      />
      <Action ID="VisualizePose" marker_name="finalpose" pose="{output_pose}" />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="MovetoGridPose">
      <MetadataFields>
        <Metadata runnable="true" />
        <Metadata subcategory="Sinter" />
      </MetadataFields>
      <inout_port
        name="output_pose"
        default="{output_pose}"
        type="geometry_msgs::msg::PoseStamped"
      />
    </SubTree>
  </TreeNodesModel>
</root>
