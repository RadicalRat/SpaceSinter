<?xml version="1.0" encoding="UTF-8" ?>
<root BTCPP_format="4" main_tree_to_execute="TransformPoseRotation">
  <BehaviorTree
    ID="TransformPoseRotation"
    _description=""
    _favorite="false"
    name="Transforms input pose according to link pose's rotation"
  >
    <Control ID="Sequence" name="TopLevelSequence">
      <Action
        ID="CreateStampedPose"
        stamped_pose="{tip_pose}"
        reference_frame="{tip_frame}"
        orientation_xyzw="0.000; 0.000; 0.000; 1.000"
      />
      <Action
        ID="TransformPoseFrame"
        input_pose="{tip_pose}"
        output_pose="{tip_world}"
      />
      <Action ID="VisualizePose" pose="{tip_world}" />
      <Action
        ID="UnpackPoseStampedMessage"
        pose_stamped="{tip_world}"
        pose="{pose}"
      />
      <Action
        ID="UnpackPoseMessage"
        pose="{pose}"
        orientation="{orientation}"
      />
      <Action
        ID="UnpackPoseStampedMessage"
        pose_stamped="{input_pose}"
        pose="{world_pose}"
        header="{world_header}"
      />
      <Action
        ID="UnpackPoseMessage"
        pose="{world_pose}"
        orientation="{world_ori}"
        position="{world_pos}"
      />
      <Action
        ID="CreatePoseMessage"
        orientation="{orientation}"
        position="{world_pos}"
        pose="{out_pose}"
      />
      <Action
        ID="CreatePoseStampedMessage"
        pose="{out_pose}"
        header="{world_header}"
        pose_stamped="{output_pose}"
      />
    </Control>
  </BehaviorTree>
  <TreeNodesModel>
    <SubTree ID="TransformPoseRotation" />
  </TreeNodesModel>
</root>
