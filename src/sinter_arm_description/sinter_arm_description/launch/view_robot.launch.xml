<?xml version="1.0" encoding="UTF-8" ?>
<launch>
  <!-- Robot State Publisher -->
  <node pkg="robot_state_publisher" exec="robot_state_publisher">
    <param
      name="robot_description"
      value="$(command 'xacro $(find-pkg-share sinter_arm_description)/urdf/j2n600s.urdf.xacro')"
    />
  </node>

  <!-- Launch joint state publisher -->
  <node pkg="joint_state_publisher_gui" exec="joint_state_publisher_gui" />

  <!-- Launch RViz2 -->
  <node
    name="rviz2"
    pkg="rviz2"
    exec="rviz2"
    args="-d $(find-pkg-share sinter_arm_description)/launch/view_robot.rviz"
    output="screen"
  />
</launch>
