<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <!--
    Kinova Jaco2 6DOF Non-Spherical (j2n6s300)
    6 DOF arm with 600x600x30mm lens payload (replaces gripper).

    Follows PickNik xacro naming conventions:
    - *_urdf_macro.xacro : macro definitions only, no output when included
    - *.urdf.xacro       : top-level file that calls macros

    Reference: https://docs.picknik.ai/how_to/configuration_tutorials/create_robot_mock_config/refactor_urdf_to_xacro/
  -->

  <xacro:macro name="j2n6s300_description" params="base_parent prefix:=j2n6s300">

    <xacro:property name="PI" value="3.1415926535897931"/>

    <!-- ========================================== -->
    <!--                 Base Link                  -->
    <!-- ========================================== -->

    <link name="${prefix}_link_base">
      <visual>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/visual/base.dae"/>
        </geometry>
        <material name="carbon_fiber">
          <color rgba="0.792 0.820 0.933 1"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/collision/base.STL"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.46784"/>
        <origin xyz="0 0 0.1255" rpy="0 0 0"/>
        <inertia ixx="0.000951" ixy="0" ixz="0"
                 iyy="0.000951" iyz="0"
                 izz="0.000374"/>
      </inertial>
    </link>

    <joint name="${prefix}_joint_base" type="fixed">
      <parent link="${base_parent}"/>
      <child link="${prefix}_link_base"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- ========================================== -->
    <!--       Link 1 - Shoulder (continuous)       -->
    <!-- ========================================== -->

    <link name="${prefix}_link_1">
      <visual>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/visual/shoulder.dae"/>
        </geometry>
        <material name="carbon_fiber"/>
      </visual>
      <visual>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/visual/ring_big.dae"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/collision/shoulder.STL"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.7477"/>
        <origin xyz="0 -0.002 -0.0605"/>
        <inertia ixx="0.001520" ixy="0" ixz="0"
                 iyy="0.001520" iyz="0"
                 izz="0.000598"/>
      </inertial>
    </link>

    <joint name="${prefix}_joint_1" type="continuous">
      <parent link="${prefix}_link_base"/>
      <child link="${prefix}_link_1"/>
      <axis xyz="0 0 1"/>
      <origin xyz="0 0 0.15675" rpy="0 ${PI} 0"/>
      <limit effort="40" velocity="${36*PI/180}"/>
      <dynamics damping="0.0" friction="0.0"/>
    </joint>

    <!-- ========================================== -->
    <!--          Link 2 - Arm (revolute)           -->
    <!-- ========================================== -->

    <link name="${prefix}_link_2">
      <visual>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/visual/arm.dae"/>
        </geometry>
        <material name="carbon_fiber"/>
      </visual>
      <visual>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/visual/ring_big.dae"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/collision/arm.STL"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.99"/>
        <origin xyz="0 -0.2065 -0.01"/>
        <inertia ixx="0.010503" ixy="0" ixz="0"
                 iyy="0.000792" iyz="0"
                 izz="0.010503"/>
      </inertial>
    </link>

    <joint name="${prefix}_joint_2" type="revolute">
      <parent link="${prefix}_link_1"/>
      <child link="${prefix}_link_2"/>
      <axis xyz="0 0 1"/>
      <origin xyz="0 0.0016 -0.11875" rpy="${-PI/2} 0 ${PI}"/>
      <limit effort="80" velocity="${36*PI/180}" lower="${47*PI/180}" upper="${313*PI/180}"/>
      <dynamics damping="0.0" friction="0.0"/>
    </joint>

    <!-- ========================================== -->
    <!--        Link 3 - Forearm (revolute)         -->
    <!-- ========================================== -->

    <link name="${prefix}_link_3">
      <visual>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/visual/forearm.dae"/>
        </geometry>
        <material name="carbon_fiber"/>
      </visual>
      <visual>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/visual/ring_big.dae"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/collision/forearm.STL"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.6763"/>
        <origin xyz="0 0.081 -0.0086"/>
        <inertia ixx="0.001420" ixy="0" ixz="0"
                 iyy="0.000304" iyz="0"
                 izz="0.001420"/>
      </inertial>
    </link>

    <joint name="${prefix}_joint_3" type="revolute">
      <parent link="${prefix}_link_2"/>
      <child link="${prefix}_link_3"/>
      <axis xyz="0 0 1"/>
      <origin xyz="0 -0.410 0" rpy="0 ${PI} 0"/>
      <limit effort="40" velocity="${36*PI/180}" lower="${19*PI/180}" upper="${341*PI/180}"/>
      <dynamics damping="0.0" friction="0.0"/>
    </joint>

    <!-- ========================================== -->
    <!--      Link 4 - Wrist 1 (continuous)         -->
    <!-- ========================================== -->

    <link name="${prefix}_link_4">
      <visual>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/visual/wrist.dae"/>
        </geometry>
        <material name="carbon_fiber"/>
      </visual>
      <visual>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/visual/ring_small.dae"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/collision/wrist.STL"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.426367"/>
        <origin xyz="0 -0.037 -0.0642"/>
        <inertia ixx="0.000077" ixy="0" ixz="0"
                 iyy="0.000077" iyz="0"
                 izz="0.000143"/>
      </inertial>
    </link>

    <joint name="${prefix}_joint_4" type="continuous">
      <parent link="${prefix}_link_3"/>
      <child link="${prefix}_link_4"/>
      <axis xyz="0 0 1"/>
      <origin xyz="0 0.2073 -0.0114" rpy="${-PI/2} 0 ${PI}"/>
      <limit effort="20" velocity="${48*PI/180}"/>
      <dynamics damping="0.0" friction="0.0"/>
    </joint>

    <!-- ========================================== -->
    <!--      Link 5 - Wrist 2 (continuous)         -->
    <!-- ========================================== -->

    <link name="${prefix}_link_5">
      <visual>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/visual/wrist.dae"/>
        </geometry>
        <material name="carbon_fiber"/>
      </visual>
      <visual>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/visual/ring_small.dae"/>
        </geometry>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://sinter_arm_description/meshes/collision/wrist.STL"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.426367"/>
        <origin xyz="0 -0.037 -0.0642"/>
        <inertia ixx="0.000077" ixy="0" ixz="0"
                 iyy="0.000077" iyz="0"
                 izz="0.000143"/>
      </inertial>
    </link>

    <joint name="${prefix}_joint_5" type="continuous">
      <parent link="${prefix}_link_4"/>
      <child link="${prefix}_link_5"/>
      <axis xyz="0 0 1"/>
      <origin xyz="0 -0.03703 -0.06414" rpy="${PI/3} 0 ${PI}"/>
      <limit effort="20" velocity="${48*PI/180}"/>
      <dynamics damping="0.0" friction="0.0"/>
    </joint>

    <!-- ========================================== -->
    <!--    Link 6 - End Cap / Mount (continuous)   -->
    <!-- ========================================== -->

    <!-- Link 6 is a virtual mount point: gripper/end effector removed, lens attaches here -->
    <link name="${prefix}_link_6">
      <inertial>
        <mass value="0.99"/>
        <origin xyz="0 0 -0.06"/>
        <inertia ixx="0.000345" ixy="0" ixz="0"
                 iyy="0.000345" iyz="0"
                 izz="0.000582"/>
      </inertial>
    </link>

    <joint name="${prefix}_joint_6" type="continuous">
      <parent link="${prefix}_link_5"/>
      <child link="${prefix}_link_6"/>
      <axis xyz="0 0 1"/>
      <origin xyz="0 -0.03703 -0.06414" rpy="${PI/3} 0 ${PI}"/>
      <limit effort="20" velocity="${48*PI/180}"/>
      <dynamics damping="0.0" friction="0.0"/>
    </joint>

    <!-- ========================================== -->
    <!--        Lens Payload (600x600x30mm)         -->
    <!--   Fixed to link_6, replaces gripper        -->
    <!-- ========================================== -->

    <link name="${prefix}_lens">
      <visual>
        <origin xyz="0 -0.01002 0.00827" rpy="0 0 0"/>
        <geometry>
          <box size="0.500 0.532 0.025"/>
        </geometry>
        <material name="lens_glass">
          <color rgba="0.3 0.3 0.8 0.5"/>
        </material>
      </visual>
      <collision>
        <origin xyz="0 -0.01002 0.00827" rpy="0 0 0"/>
        <geometry>
          <box size="0.500 0.532 0.025"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="5.0"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="0.150375" ixy="0" ixz="0"
                 iyy="0.150375" iyz="0"
                 izz="0.300000"/>
      </inertial>
    </link>

    <joint name="${prefix}_lens_joint" type="fixed">
      <parent link="${prefix}_link_6"/>
      <child link="${prefix}_lens"/>
      <origin xyz="-0.00827 0 -0.27602" rpy="${-PI/2} 0 ${-PI/2}"/>
    </joint>

    <!-- ========================================== -->
    <!--   Focal Point (400mm along lens Z-axis)    -->
    <!--   Virtual frame — no geometry/inertia      -->
    <!-- ========================================== -->

    <link name="${prefix}_focal_point"/>

    <joint name="${prefix}_focal_point_joint" type="fixed">
      <parent link="${prefix}_lens"/>
      <child link="${prefix}_focal_point"/>
      <origin xyz="0 0 0.4" rpy="0 0 0"/>
    </joint>

    <!-- ========================================== -->
    <!--   Camera Frame (reference middle of lens)  -->
    <!--   Virtual frame — no geometry/inertia      -->
    <!-- ========================================== -->

    <link name="${prefix}_suncam_optical"/>

    <joint name="${prefix}_suncam_joint" type="fixed">
      <parent link="${prefix}_lens"/>
      <child link="${prefix}_suncam_optical"/>
      <origin xyz="-0.065 -0.203 -0.03567" rpy="${PI} 0 0"/>
    </joint>



  </xacro:macro>

</robot>
